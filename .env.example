# Far7i - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ============================================
# SECURITY
# ============================================
# Generate a strong random key for encrypting localStorage
# You can use: openssl rand -base64 32
VITE_STORAGE_ENCRYPTION_KEY=your_encryption_key_here_change_in_production

# ============================================
# OPTIONAL: MONITORING & ANALYTICS
# ============================================
# Sentry DSN for error tracking (optional)
# VITE_SENTRY_DSN=your_sentry_dsn_here

# Google Analytics ID (optional)
# VITE_GA_ID=your_google_analytics_id_here

# ============================================
# DEVELOPMENT
# ============================================
# Set to 'development' or 'production'
# MODE=development

# ============================================
# NOTES
# ============================================
# 1. NEVER commit the .env file to git
# 2. Add .env to .gitignore
# 3. Use different keys for development and production
# 4. Rotate encryption keys periodically
# 5. Keep Supabase keys secure and never expose them in client-side code
